// arquivo .bed gerado pelo setup

bed {
    diameter = 0.05 m;
    height = 0.1 m;
    wall_thickness = 0.0020000000000000018 m;
    clearance = 0.01 m;
    material = "steel";
    internal_cylinder_mode = "hollow_boolean_applied";
    visibility {
        show_outer_cylinder = true;
        show_internal_cylinder = false;
        show_particles = true;
        show_boolean_tools = false;
        export_boolean_tools = false;
    }
}

lids {
    top_type = "flat";
    bottom_type = "flat";
    top_thickness = 0.003 m;
    bottom_thickness = 0.003 m;
    seal_clearance = 0.001 m;
}

particles {
    kind = "sphere";
    diameter = 0.0015 m;
    count = 80;
    target_porosity = 0.4;
    density = 2500.0 kg/m3;
    friction = 0.5;
    rolling_friction = 0.1;
    linear_damping = 0.1;
    angular_damping = 0.1;
    seed = 1;
}

packing {
    method = "hexagonal_3d";
    gravity = -9.81 m/s2;
    substeps = 10;
    iterations = 10;
    damping = 0.1;
    rest_velocity = 0.01 m/s;
    max_time = 5.0 s;
    collision_margin = 0.001 m;
    gap = 0.0001 m;
    mesh_segmentos = 24;
    sphere_lat = 3;
    sphere_lon = 5;
    strict_validation = true;
}

geometry {
    mode = "full_3d";
}

generation {
    backend = "python_engine";
}

slice {
    enabled = true;
    thickness = 0.01 m;
    axis = "y";
    position = 0.0 m;
    keep_only_intersecting_particles = true;
    preserve_original_packing = true;
}

export {
    formats = ["blend", "stl"];
    units = "m";
    scale = 1.0;
    wall_mode = "surface";
    fluid_mode = "none";
    manifold_check = true;
    merge_distance = 0.001 m;
}
