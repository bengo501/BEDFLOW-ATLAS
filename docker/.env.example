# exemplo de configuracao da stack docker do BEDFLOW-ATLAS.
# copie para docker/.env e ajuste o que precisar:   cp docker/.env.example docker/.env
# (docker/.env e ignorado pelo git via .dockerignore/.gitignore)

# --- perfil de modelagem (build da imagem do backend) ---
# 0 = imagem LEVE (so motor python; build rapido)   1 = inclui blender
WITH_BLENDER=0
# 1 = tenta instalar openfoam na imagem (best-effort em debian; CFD tb roda via WSL)
WITH_OPENFOAM=0
# runtime: "python" (motor python) ou "blender"
MODELING_PROFILE=python

# --- banco de dados ---
# default da stack: postgres do compose. para SQLITE (sem postgres), use:
#   DATABASE_URL=sqlite:////workspace/local_data/cfd_pipeline.db
DATABASE_URL=postgresql://postgres:postgres123@postgres:5432/cfd_pipeline
POSTGRES_DB=cfd_pipeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# --- minio (armazenamento de objetos) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# --- seed de dados demo no primeiro arranque (1/0) ---
SEED_DEMO_DATA=1

# --- portas publicadas no host ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- tag das imagens construidas ---
IMAGE_TAG=local
